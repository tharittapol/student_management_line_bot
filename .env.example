# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Group ID ที่ได้จาก log ตอนมีข้อความเข้ากลุ่ม LINE
LINE_STAFF_GROUP_ID=your_line_group_id

# App server
PORT=8080

# true = ส่ง daily notification ทันทีตอน start app 1 ครั้ง
# false = รอรอบแจ้งปกติทุกวัน 09:00 Asia/Bangkok
RUN_DAILY_ON_START=false

# Docker Compose host port mapping
HOST_PORT=8080

# ngrok tunnel สำหรับรับ LINE webhook ตอนรัน local ด้วย Docker
# เอาจาก https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken
NGROK_INSPECTOR_PORT=4040
