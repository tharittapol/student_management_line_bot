# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Comma-separated LINE group IDs that bot is allowed to read and notify.
# Example: LINE_GROUP_IDS=Cxxxxxxxxxxxxxxxx,Cyyyyyyyyyyyyyyyy
LINE_GROUP_IDS=

# Legacy optional fallback. Prefer LINE_GROUP_IDS for multiple groups.
LINE_STAFF_GROUP_ID=

# App server
PORT=8080

# Google Sheets database
# 1 worksheet/tab = 1 table. Share the spreadsheet with the service account email.
GOOGLE_SHEET_ID=your_google_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=base64_encoded_service_account_json
# Alternative local path if running outside Docker:
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_SHEETS_INIT_SCHEMA=true
GOOGLE_SHEETS_SEED_DIR=db/google_sheets

# true = send weekly schedule once at app startup
# false = wait for the normal 09:00 Asia/Bangkok routine
RUN_DAILY_ON_START=false

# Docker Compose host port mapping
HOST_PORT=8080

# ngrok tunnel for local LINE webhook
# Get token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken
NGROK_INSPECTOR_PORT=4040
